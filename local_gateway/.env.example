GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8787

# xiaokang 会使用 Bearer Token 连接本地网关
WS_TOKEN=local-dev-token

# 给 OTA 返回的 WebSocket 地址（本机部署默认即可）
WS_PUBLIC_URL=ws://127.0.0.1:8787/xiaokang/v1/

# 火山方舟（OpenAI 兼容）
VOLC_API_KEY=
VOLC_MODEL=ark-code-latest
VOLC_OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ASR_MODEL=whisper-1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=180
LLM_THINKING_TYPE=disabled
INJECT_CURRENT_TIME=true
CURRENT_TIMEZONE=Asia/Shanghai
LLM_STREAMING=true
STREAM_TTS_CHUNK_CHARS=24
STREAM_TTS_MIN_CHARS=24
STREAM_TTS_MAX_CHARS=52

# TTS backends: edge / volc / sherpa. sherpa is fully offline after model download.
TTS_BACKEND=edge
TTS_ALLOW_FALLBACK=false
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz
TTS_VOLUME=+0%
TTS_EDGE_RETRIES=3
TTS_EDGE_RETRY_DELAY=0.8

# sherpa-onnx VITS example, paths are relative to local_gateway/.
# Download a Chinese VITS model such as vits-melo-tts-zh_en or vits-icefall-zh-aishell3.
TTS_SHERPA_MODEL=models/vits-melo-tts-zh_en/model.onnx
TTS_SHERPA_TOKENS=models/vits-melo-tts-zh_en/tokens.txt
TTS_SHERPA_LEXICON=models/vits-melo-tts-zh_en/lexicon.txt
TTS_SHERPA_RULE_FSTS=models/vits-melo-tts-zh_en/phone.fst,models/vits-melo-tts-zh_en/date.fst,models/vits-melo-tts-zh_en/number.fst
TTS_SHERPA_SID=0
TTS_SHERPA_SPEED=1.0
TTS_SHERPA_THREADS=2

# 语音识别后端：vosk / offline_whisper / online_openai
ASR_BACKEND=vosk
VOSK_MODEL_PATH=/home/orangepi/xiaokang/local_gateway/models/vosk-model-small-cn-0.22
ASR_VOSK_STREAMING=true
ASR_TRIM_SILENCE=true
ASR_SILENCE_THRESHOLD=700
ASR_KEEP_TAIL_MS=180
ASR_MIN_AUDIO_MS=250

# 以下是 faster-whisper 可选参数（仅当 ASR_BACKEND=offline_whisper 生效）
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=zh
WHISPER_BEAM_SIZE=1
WHISPER_CPU_THREADS=4
